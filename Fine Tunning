from datasets import load_dataset

dataset = load_dataset('dominguesm/Canarim-Instruct-PTBR-Dataset', split = 'train')

dataset.to_pandas()

def gerar_prompt(instruction, input, resposta = ''):
  return f'''Você é um modelo poderoso de conhecimento. Seu trabalho é responder de modo assertivo às perguntas que te fazem com base no seu conhecimento

  ### Instruction:
  Intruction: {instruction}

