print(gerar_prompt(dataset[316408]['instruction'], dataset[316408]['input']), dataset[316408]['output'])

EOS_TOKEN = tokenizador.eos_token

def formatar_prompts(dados):
  contextos = dados['instruction']
  perguntas = dados['input']
  respostas = dados['output']
  textos = []
  for contexto, pergunta, resposta in zip(contextos, perguntas, respostas):
    texto = gerar_prompt(contexto, pergunta, resposta) + EOS_TOKEN
    textos.append(texto)
  return {'texto' : textos,}

dataset = dataset.map(formatar_prompts, batched = True)

modelo = FastLanguageModel.get_peft_model(
    modelo,
    r = 16,
    target_modules = ['q_proj', 'k_proj', 'v_proj', 'o_proj', 'gate_proj', 'u_proj','down_proj'],
    lora_alpha = 16,
    lora_dropout = 0,
    bias = 'none',
    use_gradient_checkpointing = 'unsloth',
    random_state = 10,
    use_rslora = False,
    loftq_config = None

)

from trl import SFTTrainer
from transformers import TrainingArguments
from unsloth import is_bfloat16_supported

trainer = SFTTrainer( # Inicializa o treinador de Supervised Fine-Tuning (SFT)
    model = modelo, # Define o modelo de linguagem que receberá o fine-tuning
    tokenizer = tokenizador, # Passa o tokenizador responsável por converter textos em números
    train_dataset = dataset, # Especifica a base de dados que será usada no treinamento
    max_seq_length = 2048, # Define o tamanho máximo de tokens por sequência de texto
    dataset_text_field = 'texto', # Indica o nome da coluna do dataset que contém o texto de treino
    dataset_num_proc = 1, # Define o número de processos de CPU para preparar os dados
    packing = False, # Desativa o agrupamento de textos curtos em uma mesma sequência de 2048 tokens
    formatting_func = formatar_prompts, # Adiciona a função de formatação de prompts
    args = TrainingArguments( # Inicia a configuração dos hiperparâmetros de treino
        per_device_train_batch_size = 2, # Define quantos exemplos serão processados por GPU de cada vez
        gradient_accumulation_steps = 4, # Acumula gradientes por 4 passos antes de atualizar o modelo (batch virtual = 8)
        warmup_steps = 5, # Aumenta a taxa de aprendizado gradualmente nos primeiros 5 passos do treino
        learning_rate = 2e-5, # Define a taxa de aprendizado inicial (2 inicializada com base em notação científica)
        max_steps = 60, # Determina que o treinamento irá parar após exatamente 60 passos de execução
        fp16 = not is_bfloat16_supported(), # Ativa precisão fp16 se a GPU antiga não suportar o formato bf16
        bf16 = is_bfloat16_supported(), # Ativa precisão de última geração bf16 se a GPU atual for compatível
        logging_steps = 1, # Exibe as métricas de perda (loss) na tela a cada 1 passo concluído
        output_dir = 'outputs', # Define a pasta do sistema onde o modelo treinado será salvo
        optim = 'adamw_8bit', # Usa o otimizador AdamW de 8 bits paginado para economizar memória VRAM
    ) # Fecha as configurações de argumentos de treino
) # Fecha a inicialização do SFTTrainer
